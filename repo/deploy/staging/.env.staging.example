# Static staging configuration.
# The GitHub Environment secret STAGING_ENV_FILE should contain these values.
# deploy_staging.sh merges this base content with dynamic image metadata on the host.

# Placeholder image metadata so this file is self-contained for local compose validation.
# deploy_staging.sh overwrites these values during a real staging deploy.
BACKEND_IMAGE=ghcr.io/example/foodbiz-backend
IMAGE_TAG=staging
APP_VERSION=local-validate

POSTGRES_USER=foodbiz
POSTGRES_PASSWORD=change-me
POSTGRES_DB=foodbiz

BACKEND_PORT=8000
CORS_ALLOW_ORIGINS=https://staging.example.com

OTEL_SERVICE_NAME=rop-backend
OTEL_EXPORTER_OTLP_ENDPOINT=

STAGING_RUN_SEED=true
SMOKE_BASE_URL=http://127.0.0.1:8000
SMOKE_RESTAURANT_ID=rst_001
