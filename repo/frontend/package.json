{
  "name": "rop-frontend",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "pnpm --filter web-ordering dev",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "dev:staff-console": "pnpm --filter dashboard dev",
    "dev:kitchen": "pnpm --filter kitchen-display dev",
    "dev:restaurant-site": "pnpm --filter restaurant-site dev",
    "build:staff-console": "pnpm --filter dashboard build",
    "build:kitchen": "pnpm --filter kitchen-display build",
    "build:web-ordering": "pnpm --filter web-ordering build",
    "build:restaurant-site": "pnpm --filter restaurant-site build",
    "test:unit": "vitest run",
    "test:e2e": "pnpm run build:staff-console && pnpm run build:kitchen && pnpm run build:web-ordering && pnpm run build:restaurant-site && playwright test",
    "test": "pnpm run test:unit && pnpm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "happy-dom": "^20.8.9",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vitest": "^1.6.1"
  }
}
